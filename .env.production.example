# .env.production — template for the Wave 9 launch.
#
# Copy this file to `.env.production` and fill in the real values.
# `.env.production` is gitignored — never commit the populated file.
#
# Two audiences consume this:
#   1. `expo start` / local production-mode dev reads EXPO_PUBLIC_*
#      variables directly. Any var intended for the React Native
#      runtime *must* be prefixed `EXPO_PUBLIC_` or it won't reach
#      the JS bundle.
#   2. EAS Build reads the `.env.production` at the project root
#      when you pass `--env-file .env.production`, but prefers
#      secrets registered with `eas secret:create` (see DEPLOY.md §1.2).
#      When both are set, EAS secrets win.

# ── windy-pro account-server (JWKS / OAuth / ecosystem status) ──
# The base URL every service points at. Production = the public
# windyword.ai host. Staging = `https://staging.windyword.ai` (not set up
# on this branch — use prod + a test license for now).
EXPO_PUBLIC_API_URL=https://windyword.ai

# ── Sentry crash reporting ──────────────────────────────────────
# From https://sentry.io/settings/{org}/projects/windy-word-mobile/keys/
# Optional but strongly recommended for launch — `_layout.tsx` no-ops
# when the DSN is empty.
EXPO_PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@oXXXXXX.ingest.sentry.io/PROJECT_ID

# ── Google Cloud Vision OCR (camera translate) ──────────────────
# Registered as an EAS secret named `google-vision-api-key`
# (see eas.json production.env.GOOGLE_VISION_API_KEY = "@google-vision-api-key").
# The value below is only a local-dev fallback; production builds
# use the EAS secret.
GOOGLE_VISION_API_KEY=AIza________________________________

# ── Firebase Cloud Messaging (Android push) ─────────────────────
# Registered as an EAS secret named `fcm-server-key`
# (eas.json production.env.FCM_SERVER_KEY = "@fcm-server-key").
# Legacy server key form — see DEPLOY.md §5.2 for HTTP v1 migration.
FCM_SERVER_KEY=AAAA_____________________________

# ── RevenueCat (in-app purchases) ───────────────────────────────
# One key per platform. See DEPLOY.md §6. Wiring lives in
# app.json `extra.revenueCatIosKey` / `revenueCatAndroidKey` — at build
# time these are substituted from EAS secrets.
REVENUECAT_IOS_KEY=appl_________________________________
REVENUECAT_ANDROID_KEY=goog_________________________________

# ── Apple App Store Connect ─────────────────────────────────────
# Apple ID that owns the app record. Must match eas.json
# submit.production.ios.appleId (currently grantwhitmer3@gmail.com).
APPLE_ID=grantwhitmer3@gmail.com
# The numeric App Store Connect App ID (Apple's internal id, not the
# bundle id). Already pinned in eas.json — duplicated here so build
# tooling that doesn't read eas.json (notarization scripts, fastlane)
# can still resolve it.
ASC_APP_ID=6759985867
# 10-character Apple Developer Team ID.
APPLE_TEAM_ID=VXZ434QL89
# Path to the App Store Connect API key (.p8). Used by `eas submit` and
# any local fastlane / altool invocation. Do NOT commit the .p8.
ASC_API_KEY_PATH=./secrets/AuthKey_ABC12DE3FG.p8
# ASC API Key ID + Issuer ID. From App Store Connect → Users and Access
# → Integrations → App Store Connect API.
ASC_API_KEY_ID=ABC12DE3FG
ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000

# ── APNs push certificate ───────────────────────────────────────
# Path to the .p8 downloaded from Apple Developer → Keys → APNs.
# Pointed at once via `eas credentials` — see DEPLOY.md §5.1.
APNS_KEY_PATH=./secrets/AuthKey_XYZ98WV7UT.p8
APNS_KEY_ID=XYZ98WV7UT

# ── Google Play Console ─────────────────────────────────────────
# Service-account JSON key with `Release manager` permissions on the
# Play Console. Not committed. `eas submit` reads this to upload AABs.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=./secrets/play-service-account.json

# ── EAS ─────────────────────────────────────────────────────────
# Bypasses the interactive `eas login` step on CI. Generate via
# `eas login` then inspect `~/.expo/state.json`, or create a
# robot-account token at https://expo.dev/settings/access-tokens.
EXPO_TOKEN=
