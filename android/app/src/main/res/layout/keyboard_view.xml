<?xml version="1.0" encoding="utf-8"?>
<!-- Windy Word Keyboard — Voice input IME layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0f172a"
    android:padding="8dp">

    <!-- Status bar: shows recording state, timer, transcript preview -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap 🌪️ to speak"
        android:textColor="#94a3b8"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <!-- Transcript preview (visible during/after transcription) -->
    <TextView
        android:id="@+id/transcriptPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#e2e8f0"
        android:textSize="14sp"
        android:gravity="center"
        android:maxLines="3"
        android:ellipsize="end"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <!-- Button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp">

        <!-- Switch to default keyboard -->
        <ImageButton
            android:id="@+id/switchKeyboardBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch keyboard"
            android:tint="#64748b" />

        <!-- Main tornado/mic button -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="24dp">

            <!-- Glow ring (recording indicator) -->
            <View
                android:id="@+id/glowRing"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:alpha="0" />

            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="@android:color/transparent"
                android:scaleType="centerInside"
                android:contentDescription="Voice input"
                android:tint="#a3e635" />
        </FrameLayout>

        <!-- Backspace -->
        <ImageButton
            android:id="@+id/backspaceBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_input_delete"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Backspace"
            android:tint="#64748b" />
    </LinearLayout>

    <!-- Timer (visible during recording) -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#ef4444"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="4dp"
        android:visibility="gone" />
</LinearLayout>
