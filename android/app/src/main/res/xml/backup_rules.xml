<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android 12 backup rules.
  Excludes sensitive token/auth data from cloud backup.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="expo-secure-store/" />
</full-backup-content>
