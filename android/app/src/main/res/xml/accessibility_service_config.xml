<?xml version="1.0" encoding="utf-8"?>
<!--
  🧬 M4.4 — Accessibility Service Configuration
  Capabilities for paste-at-cursor functionality.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewFocused|typeViewTextChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows"
    android:canPerformGestures="true"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity="uk.thewindstorm.windypro.MainActivity" />
