{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "base": {
            "node": "22.13.0",
            "env": {
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
                "SENTRY_DISABLE_AUTO_UPLOAD": "true"
            }
        },
        "development": {
            "extends": "base",
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "extends": "base",
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease"
            },
            "ios": {
                "simulator": true
            }
        },
        "production": {
            "extends": "base",
            "autoIncrement": true,
            "distribution": "store",
            "env": {
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
                "EXPO_PUBLIC_API_URL": "https://account.windyword.ai",
                "GOOGLE_VISION_API_KEY": "@google-vision-api-key",
                "SENTRY_DISABLE_AUTO_UPLOAD": "true"
            },
            "android": {
                "buildType": "app-bundle",
                "gradleCommand": ":app:bundleRelease",
                "credentialsSource": "remote"
            },
            "ios": {
                "credentialsSource": "remote",
                "resourceClass": "m-medium"
            }
        },
        "development-sim": {
            "extends": "base",
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleId": "grantwhitmer3@gmail.com",
                "appleTeamId": "VXZ434QL89",
                "ascAppId": "6759985867",
                "bundleIdentifier": "uk.thewindstorm.windypro",
                "groups": [
                    "Team (Expo)"
                ]
            },
            "android": {
                "track": "internal",
                "releaseStatus": "draft"
            }
        }
    }
}