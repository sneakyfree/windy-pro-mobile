{
    "cli": {
        "version": ">= 13.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease"
            },
            "ios": {
                "simulator": true
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle",
                "gradleCommand": ":app:bundleRelease"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "ascAppId": "WINDY_PRO_APP_ID"
            },
            "android": {
                "track": "internal",
                "releaseStatus": "draft"
            }
        }
    }
}